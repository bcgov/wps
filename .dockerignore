# We want to exclude a whole bunch of stuff for docker. Otherwise docker pulls a bunch of
# file it doesn't need into it's context when doing a build, which can slow down things.
.githooks
.github
.vscode
.zap
.architecture
.gitignore
.ipynb_checkpoints
node_modules
mobile/**
web/build
web/**/node_modules
web/apps/wps-web/coverage
web/apps/wps-web/coverage-playwright
web/apps/wps-web/.nyc_output
web/apps/wps-web/.nyc_temp_playwright
web/apps/wps-web/playwright
web/apps/wps-web/.pnp.*
web/apps/wps-web/.yarn/*
!web/.yarn/patches
!web/.yarn/plugins
!web/.yarn/releases
!web/.yarn/sdks
!web/.yarn/versions
.dockerignore
grib
**/Dockerfile*
**/junk
**/scripts
**/python_cache*
**/__pycache__
**/*.pyc
**/*.zip
**/*.grib2
**.venv
*/nbconvert/*