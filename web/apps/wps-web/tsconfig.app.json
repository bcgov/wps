{
  "extends": "@wps/tsconfig/react-app.json",
  "compilerOptions": {
    "types": [
      "vite/client",
      "node",
      "vitest/globals",
      "@testing-library/jest-dom",
      "@wps/types"
    ],
    "noUnusedLocals": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@wps/api/*": [
        "../../packages/api/src/*"
      ],
      "@wps/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@wps/utils/*": [
        "../../packages/utils/src/*"
      ],
      "@wps/types/*": [
        "../../packages/types/src/*"
      ],
      "@/*": [
        "./src/*"
      ],
      "#root/*": [
        "./*"
      ],
      "app/*": [
        "./src/app/*"
      ],
      "features/*": [
        "./src/features/*"
      ],
      "commonSlices/*": [
        "./src/commonSlices/*"
      ],
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/setupTests.ts"
  ]
}