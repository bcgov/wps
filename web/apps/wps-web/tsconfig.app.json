{
  "extends": "@wps/tsconfig/react-app.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["vite/client", "node", "vitest/globals", "@testing-library/jest-dom", "@wps/types"],
    "noUnusedLocals": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/app/theme": ["../../packages/ui/src/theme"],
      "@/api/*": ["../../packages/api/src/*"],
      "@/utils/*": ["../../packages/utils/src/*"],
      "@/components/*": ["../../packages/ui/src/*"],
      "#root/*": ["./*"],
      "app/theme": ["../../packages/ui/src/theme"],
      "app/*": ["./src/app/*"],
      "utils/*": ["../../packages/utils/src/*"],
      "api/*": ["../../packages/api/src/*"],
      "features/*": ["./src/features/*"],
      "components/*": ["../../packages/ui/src/*"],
      "components": ["../../packages/ui/src/index"],
      "commonSlices/*": ["./src/commonSlices/*"],
      "types/*": ["../../packages/types/src/*"]
    }
  },
  "references": [
    { "path": "../../packages/api" },
    { "path": "../../packages/utils" },
    { "path": "../../packages/ui" },
    { "path": "../../packages/types" }
  ],
  "include": ["src"]
}
