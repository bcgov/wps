{
  "name": "wps-frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697",
  "resolutions": {
    "react-is": "19.2.7"
  },
  "dependenciesMeta": {
    "@psu/cffdrs_ts": {
      "built": true
    }
  },
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "dev": "turbo dev",
    "playwright:ci": "turbo playwright:ci",
    "coverage:ci": "turbo coverage:ci",
    "finalizeCoverage": "yarn workspace @wps/wps-web run finalizeCoverage",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@vitest/coverage-v8": "^4.1.0",
    "turbo": "^2.0.0",
    "typescript": "^7.0.0",
    "vitest": "^4.1.0"
  }
}
