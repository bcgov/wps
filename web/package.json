{
  "name": "wps-frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "yarn@4.13.0",
  "resolutions": {
    "react-is": "18.3.1"
  },
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "dev": "turbo dev",
    "playwright:ci": "turbo playwright:ci",
    "coverage:ci": "turbo coverage:ci",
    "finalizeCoverage": "yarn workspace @wps/wps-web run finalizeCoverage",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@vitest/coverage-v8": "^4.1.0",
    "turbo": "^2.0.0",
    "typescript": "^5.2.2",
    "vitest": "^4.1.0"
  }
}
