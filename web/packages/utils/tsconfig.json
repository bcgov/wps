{
  "extends": "@wps/tsconfig/base.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es2015",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "types": ["vite/client", "vitest/globals", "@wps/types"],
    "outDir": "dist",
    "declaration": true,
    "customConditions": ["development"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
