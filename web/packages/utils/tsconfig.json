{
  "extends": "@wps/tsconfig/base.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es2015",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "types": ["vite/client", "vitest/globals", "@wps/types"],
    "baseUrl": ".",
    "paths": {
      "utils/*": ["./src/*"],
      "@wps/types/*": ["../types/src/*"]
    }
  },
  "references": [{ "path": "../types" }],
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
