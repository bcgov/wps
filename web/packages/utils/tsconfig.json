{
  "extends": "@wps/tsconfig/base.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es2015",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["vite/client", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "utils/*": ["./src/*"],
      "api/*": ["../api/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "../types/src"]
}
