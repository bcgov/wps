{
  "name": "@wps/utils",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./*": {
      "development": [
        "./src/*.ts",
        "./src/*.tsx"
      ],
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "dependencies": {
    "axios": "1.8.2",
    "lodash": "^4.17.21",
    "luxon": "^3.0.2",
    "ol": "10.0.0",
    "ol-mapbox-style": "^13.1.1"
  },
  "devDependencies": {
    "@wps/types": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "coverage:ci": "vitest run --coverage",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo"
  }
}
