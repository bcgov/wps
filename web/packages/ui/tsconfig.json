{
  "extends": "@wps/tsconfig/react-app.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "customConditions": [
      "development"
    ],
    "types": [
      "vite/client",
      "vitest/globals",
      "@testing-library/jest-dom",
      "@wps/types"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
