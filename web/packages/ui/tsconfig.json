{
  "extends": "@wps/tsconfig/react-app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "app/theme": ["./src/theme"],
      "api/*": ["../api/src/*"],
      "utils/*": ["../utils/src/*"],
      "components/*": ["./src/*"],
      "components": ["./src/index"]
    }
  },
  "references": [{ "path": "../api" }, { "path": "../utils" }],
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
