{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "composite": true,
    "useDefineForClassFields": true,
    "moduleResolution": "bundler",
    "jsxImportSource": "@emotion/react",
    "isolatedModules": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "target": "es2015",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "module": "esnext"
  }
}
