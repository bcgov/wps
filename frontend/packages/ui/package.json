{
  "name": "@wps/ui",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./*": {
      "development": [
        "./src/*.ts",
        "./src/*.tsx"
      ],
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "coverage:ci": "vitest run --coverage",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/system": "^9.0.0",
    "@mui/x-data-grid-pro": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.0",
    "@sentry/react": "^10.0.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "^18.3.0",
    "@wps/api": "workspace:*",
    "date-fns": "^4.0.0",
    "lodash": "^4.17.21",
    "luxon": "^3.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@wps/types": "workspace:*"
  }
}
