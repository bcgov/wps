packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
!packages/types/src/window.d.ts
apps/wps-web/src/**/*.js
apps/wps-web/src/**/*.js.map
apps/wps-web/src/**/*.d.ts
apps/wps-web/src/**/*.d.ts.map